# ── AWS ──────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=<YOUR_AWS_ACCESS_KEY_ID>
AWS_SECRET_ACCESS_KEY=<YOUR_AWS_SECRET_ACCESS_KEY>
AWS_REGION=us-east-1

# ── Bedrock ──────────────────────────────────────────────────
BEDROCK_MODEL_DEFAULT=us.amazon.nova-micro-v1:0
BEDROCK_GUARDRAIL_ID=
BEDROCK_GUARDRAIL_VERSION=DRAFT

# ── Datadog ──────────────────────────────────────────────────
DD_API_KEY=<YOUR_DATADOG_API_KEY>
DD_APP_KEY=<YOUR_DATADOG_APP_KEY>
DD_SITE=us5.datadoghq.com
DD_MCP_URL=https://mcp.us5.datadoghq.com/api/unstable/mcp-server/mcp

# ── LLM Observability ────────────────────────────────────────
DD_LLMOBS_ENABLED=1
DD_LLMOBS_AGENTLESS_ENABLED=1
DD_LLMOBS_ML_APP=sre-oncall-agent

# ── Agent ────────────────────────────────────────────────────
MAX_ITERATIONS=10
FIREWALL_THRESHOLD=0.5

# ── Auto-triage (Point C) ────────────────────────────────────
SLACK_WEBHOOK_URL=                 # Slack incoming webhook (optional; empty = no Slack)
FT_TRIAGE_TOKEN=                   # shared secret for POST /triage (optional but recommended)
